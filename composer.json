{
    "name": "enflares/framework",
    "description": "The Enflares PHP Framework.",
    "type": "library",
    "license": "MIT",
    "version": "1.0.0",
    "authors": [{
        "name": "Shaotang Zhang",
        "email": "shaotang.zhang@gmail.com"
    }],
    "support": {
        "issues": "https://github.com/enflares/framework/issues",
        "source": "https://github.com/enflares/framework"
    },
    "require": {
        "php": "^7.2.5",
        "ext-dom": "*",
        "ext-json": "*",
        "ext-libxml": "*",
        "ext-mysqli": "*",
        "ext-mbstring": "*",
        "ext-openssl": "*",
        "ext-simplexml": "*",
        "ext-gd": "*"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "enflares\\Ui\\": "vendor/enflares/ui/src/",
            "enflares\\": "vendor/enflares/framework/src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "prefer-stable": true,
    "scripts": {
        "post-root-package-install": []
    }
}